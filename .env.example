# ⚠️  Copier en .env.local (dev) — Ces variables sont à configurer dans Vercel Dashboard en production
# Ne jamais commiter de vraies clés dans ce fichier.

# Groq API
GROQ_API_KEY=your_groq_api_key_here

# Gumroad → https://app.gumroad.com/settings/advanced (Personal Access Token)
GUMROAD_ACCESS_TOKEN=your_gumroad_access_token_here
# Gumroad Product ID → le "permalink" de ton produit (ex: "abcde" dans gumroad.com/l/abcde)
GUMROAD_PRODUCT_ID=your_product_permalink_here

# Supabase → https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# URL publique du site (utilisée pour les redirections Gumroad après paiement)
# En production Vercel, VERCEL_URL est auto-injecté — tu peux laisser vide
# En dev local avec "vercel dev" : http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://your-domain.com
