# ⚠️  Copier en .env.local (dev) — Ces variables sont à configurer dans Vercel Dashboard en production
# Ne jamais commiter de vraies clés dans ce fichier.

# Groq API → https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# SumUp → https://me.sumup.com/settings/api-keys
SUMUP_API_KEY=sup_sk_your_key_here
SUMUP_MERCHANT_CODE=your_merchant_code_here

# Supabase → https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# URL publique du site (utilisée pour les redirections SumUp après paiement)
# En production Vercel, VERCEL_URL est auto-injecté — tu peux laisser vide
# En dev local avec "vercel dev" : http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://your-domain.com
